  // The _name field MUST match the client-side class name registered
  // via [CustomParent], i.e. "HackerDeviceItem".
  "48048b8a031d1c9aac192451": {
    "_id": "48048b8a031d1c9aac192451",
    "_name": "HackerDeviceItem",
    "_parent": "5c99f98d86f7745c314214b3",
    "_type": "Node",
    "_props": {},
    "addToContainerFilters": false,
    "containers": []
  }
}
